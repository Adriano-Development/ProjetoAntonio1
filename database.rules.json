{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin' && root.child('users').child(auth.uid).child('active').val() === true",
        ".validate": "newData.hasChildren(['email', 'role', 'active']) && newData.child('email').isString() && newData.child('role').val().matches(/^(admin|user)$/) && newData.child('active').isBoolean()"
      }
    },

    "leadvision_units": {
      "$unit": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('units').child($unit).val() === true)",
        ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'admin'",

        "masterData": {
          "$i": {
            "$campo": {
              ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('units').child($unit).val() === true && data.exists()"
            }
          }
        },

        "acompanhamentos": {
          "$lead": {
            ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('units').child($unit).val() === true)",
            "contatoRealizado": { ".validate": "newData.val() === '' || newData.val() === 'SIM' || newData.val() === 'NAO'" },
            "houveRetorno":     { ".validate": "newData.val() === '' || newData.val() === 'SIM' || newData.val() === 'NAO'" },
            "vaiMatricular":    { ".validate": "newData.val() === '' || newData.val() === 'SIM' || newData.val() === 'NAO' || newData.val() === 'TALVEZ'" },
            "motivoNao":        { ".validate": "newData.isString() && newData.val().length < 5000" },
            "observacaoTalvez": { ".validate": "newData.isString() && newData.val().length < 5000" },
            "nomeContato":      { ".validate": "newData.isString() && newData.val().length < 300" }
          }
        },

        "atualizadoEm": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('units').child($unit).val() === true)",
          ".validate": "newData.isString() && newData.val().length < 40"
        }
      }
    },

    "rematricula": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true",

      "base": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      },

      "tracking": {
        "$k": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true",
          "resultado":     { ".validate": "newData.isString() && newData.val().length < 100" },
          "responsavel":   { ".validate": "newData.isString() && newData.val().length < 300" },
          "observacao":    { ".validate": "newData.isString() && newData.val().length < 5000" },
          "atualizadoPor": { ".validate": "newData.isString() && newData.val().length < 200" },
          "atualizadoEm":  { ".validate": "newData.isString() && newData.val().length < 40" },
          "$other":        { ".validate": false }
        }
      }
    },

    "config": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    }
  }
}
